<Window x:Class="ComfyDeployControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comfy Launch Control" Height="900" Width="1360"
        MinHeight="760" MinWidth="1120"
        WindowStartupLocation="CenterScreen"
        Background="#080B10"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#284154"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#111821" Offset="0"/>
                        <GradientStop Color="#0F1B1E" Offset="0.54"/>
                        <GradientStop Color="#1A161C" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#05070A" BlurRadius="18" ShadowDepth="4" Opacity="0.30"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepPanel" TargetType="Border">
            <Setter Property="Padding" Value="10,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#263244"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="SoftButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F6FAFF"/>
            <Setter Property="Background" Value="#17212C"/>
            <Setter Property="BorderBrush" Value="#3B6072"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1B2C34" Offset="0"/>
                                    <GradientStop Color="#203046" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Rectangle Width="3" HorizontalAlignment="Left" RadiusX="2" RadiusY="2" Fill="#7BD7C1" Opacity="0.78" Margin="-5,1,8,1"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7BD7C1"/>
                                <Setter TargetName="Root" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#35B8A8" BlurRadius="15" ShadowDepth="0" Opacity="0.34"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SoftButton}">
            <Setter Property="BorderBrush" Value="#F0B35A"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1320"/>
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="CaretBrush" Value="#F09A62"/>
            <Setter Property="BorderBrush" Value="#2E3A4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#0D1320"/>
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="CaretBrush" Value="#F09A62"/>
            <Setter Property="BorderBrush" Value="#2E3A4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D1320"/>
            <Setter Property="Foreground" Value="#EDF2F7"/>
            <Setter Property="BorderBrush" Value="#2E3A4B"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8E0EA"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#070A10" Offset="0"/>
                <GradientStop Color="#0B2022" Offset="0.45"/>
                <GradientStop Color="#21151B" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="96"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="28,18" BorderBrush="#223044" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Comfy Launch Control" FontSize="32" FontWeight="Black" Foreground="#FFFFFF"/>
                    <TextBlock Text="Bake custom nodes into Docker, then deploy Modal when you are ready."
                               Foreground="#B7C8D8" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CancelButton" Style="{StaticResource SoftButton}" Content="Cancel task" Click="CancelOperation_Click" IsEnabled="False"/>
                    <Border CornerRadius="6" Padding="14,10" Background="#111827" BorderBrush="#304157" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#F0B35A" Margin="0,0,10,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:1.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock x:Name="StatusText" Text="Idle" FontWeight="SemiBold" Foreground="#F6D08A"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,20,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border x:Name="SetupPanel" Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Setup Assistant" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock x:Name="SetupSummaryText" Text="Connect the tools once, then the controls unlock."
                                       TextWrapping="Wrap" Foreground="#AEBBCD" Margin="0,6,0,14"/>

                            <Border Style="{StaticResource StepPanel}">
                                <StackPanel>
                                    <TextBlock Text="1. GitHub" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="GitHubStepText" Text="Not checked" TextWrapping="Wrap" Foreground="#9EADBF" Margin="0,4,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PrimaryButton}" Content="Connect GitHub" Click="ConnectGitHub_Click"/>
                                        <Button Style="{StaticResource SoftButton}" Content="Check" Click="CheckAccess_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StepPanel}">
                                <StackPanel>
                                    <TextBlock Text="2. Modal" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="ModalStepText" Text="Not checked" TextWrapping="Wrap" Foreground="#9EADBF" Margin="0,4,0,10"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="Connect Modal" Click="ConnectModal_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StepPanel}">
                                <StackPanel>
                                    <TextBlock Text="3. DockerHub" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBlock x:Name="DockerStepText" Text="Enter DockerHub credentials, then store them as GitHub Actions secrets."
                                               TextWrapping="Wrap" Foreground="#9EADBF" Margin="0,4,0,10"/>
                                    <TextBlock Text="DockerHub username"/>
                                    <TextBox x:Name="DockerUsernameBox"/>
                                    <TextBlock Text="DockerHub token"/>
                                    <PasswordBox x:Name="DockerTokenBox"/>
                                    <Button Style="{StaticResource PrimaryButton}" Content="Save Docker secrets" Click="ConfigureSecrets_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Expander Header="Advanced repository settings" Foreground="#D8E0EA" Margin="0,4,0,0">
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="GitHub owner"/>
                                    <TextBox x:Name="GitHubOwnerBox"/>
                                    <TextBlock Text="GitHub repo"/>
                                    <TextBox x:Name="GitHubRepoBox"/>
                                    <TextBlock Text="Local repo path"/>
                                    <TextBox x:Name="RepoPathBox"/>
                                    <TextBlock Text="Docker namespace / repo"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DockerNamespaceBox"/>
                                        <TextBox Grid.Column="2" x:Name="DockerRepoBox"/>
                                    </Grid>
                                    <Button Style="{StaticResource SoftButton}" Content="Save settings" Click="SaveSettings_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Modal Deployment" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="App name"/>
                            <TextBox x:Name="ModalAppBox"/>
                            <TextBlock Text="Volume name"/>
                            <TextBox x:Name="ModalVolumeBox"/>
                            <TextBlock Text="GPU for next deploy"/>
                            <ComboBox x:Name="GpuBox">
                                <ComboBoxItem Content="A10"/>
                                <ComboBoxItem Content="L40S"/>
                                <ComboBoxItem Content="A100"/>
                                <ComboBoxItem Content="H100"/>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource SoftButton}" Content="Open ComfyUI" Click="OpenComfy_Click"/>
                                <Button Style="{StaticResource SoftButton}" Content="Open Jupyter" Click="OpenJupyter_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource SoftButton}" Content="Deploy latest image" Click="Deploy_Click"/>
                                <Button Style="{StaticResource SoftButton}" Content="Stop app" Click="StopApp_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="MainControlsPanel" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,14,8">
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Nodes staged" Foreground="#91D6B4"/>
                            <TextBlock x:Name="NodeCountText" Text="-" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Image build" Foreground="#F0B35A"/>
                            <TextBlock x:Name="BuildStatusText" Text="Unknown" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Docker image" Foreground="#8AC7E8"/>
                            <TextBlock x:Name="ImageText" Text="anqipudding/modal_comfyui:latest" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Panel}">
                        <StackPanel>
                            <TextBlock Text="Auto bake" Foreground="#E78F8E"/>
                            <TextBlock x:Name="WatcherText" Text="Off" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1" Style="{StaticResource Panel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Custom node image bake" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="Install nodes in ComfyUI Manager and restart ComfyUI. This app watches the staged nodes and bakes a new Docker image for the next deploy."
                                       TextWrapping="Wrap" Foreground="#AEBBCD" Margin="0,5,12,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <CheckBox x:Name="AutoWatchBox" Content="Auto bake after node changes"
                                          Foreground="#D7DEE8" Margin="0,0,20,0" Checked="AutoWatch_Changed" Unchecked="AutoWatch_Changed"/>
                                <CheckBox x:Name="PruneTagsBox" Content="Delete old DockerHub sha tags"
                                          Foreground="#D7DEE8" Margin="0,0,20,0"/>
                                <TextBlock Text="Keep" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="KeepTagsBox" Text="3" Width="54" Margin="0,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Width="260">
                            <Button Style="{StaticResource PrimaryButton}" Content="Bake image for next deploy" Click="RunPipeline_Click"/>
                            <Button Style="{StaticResource SoftButton}" Content="Force bake current repo" Click="ForceBuild_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="2" Margin="0,0,14,14" Background="#101521" BorderBrush="#263244">
                    <TabItem Header="Activity">
                        <Grid Background="#101521">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="14" Padding="14" Background="#151A24" BorderBrush="#263244" BorderThickness="1" CornerRadius="8">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                        <TextBlock Text="Staged custom nodes" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,10,10"/>
                                        <Button Style="{StaticResource SoftButton}" Content="Refresh" Padding="10,6" Click="RefreshNodes_Click"/>
                                    </StackPanel>
                                    <ListBox x:Name="NodeList" Background="#0D1320" Foreground="#D7DEE8" BorderBrush="#2E3A4B"/>
                                </DockPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="0,14,14,14" Padding="14" Background="#0D1320" BorderBrush="#263244" BorderThickness="1" CornerRadius="8">
                                <TextBox x:Name="PipelineLogBox" Background="#080B10" Foreground="#CDE3D5" FontFamily="Consolas"
                                         BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Build history">
                        <DockPanel Background="#101521" Margin="14">
                            <Button DockPanel.Dock="Top" Style="{StaticResource SoftButton}" Content="Refresh build history" HorizontalAlignment="Left" Click="RefreshBuilds_Click"/>
                            <TextBox x:Name="BuildHistoryBox" Background="#080B10" Foreground="#FFFFFF" FontFamily="Consolas"
                                     BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Text="Install nodes in ComfyUI Manager, restart ComfyUI once, and this app prepares the next Docker image without redeploying your live session."
                   Foreground="#8FA2B8" Margin="28,0,0,10" VerticalAlignment="Center"/>
    </Grid>
</Window>
